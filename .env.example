# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME"

# Auth
JWT_SECRET="change-me"
APPLE_CLIENT_ID="com.pushmeup.app"
APPLE_TEAM_ID="YOUR_APPLE_TEAM_ID"
APPLE_KEY_ID="YOUR_APPLE_SIGN_IN_KEY_ID"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"

# CORS — comma-separated list of allowed origins. Required in production;
# if unset in non-production, CORS falls back to permissive for local dev.
ALLOWED_ORIGINS="https://your-domain.example"

# Rate limiting. In production behind a single load balancer/proxy, keep
# TRUST_PROXY=1 so per-IP limits use the client IP instead of the proxy IP.
TRUST_PROXY="1"
RATE_LIMIT_WINDOW_MS="900000"
GLOBAL_RATE_LIMIT_MAX="1200"
WRITE_RATE_LIMIT_MAX="100"

# Seeded launch push activity. Defaults off unless explicitly enabled.
SEEDED_PUSHES_ENABLED="false"
SEEDED_PUSH_MIN="1"
SEEDED_PUSH_MAX="3"
SEEDED_PEOPLE_API_URL="https://randomuser.me/api/?results=30&seed=taskswap-launch-real-portraits"

# App links / sharing
APP_WEB_ORIGIN="https://your-domain.example"
REFERRAL_SHARE_DEFAULT_TITLE="Invite to TaskSwap"
REFERRAL_SHARE_DEFAULT_MSG="Join me on TaskSwap — manage and share your tasks easily!"

# Optional (Firebase Dynamic Links short URLs)
FDL_DOMAIN_URI_PREFIX="https://yourapp.page.link"
FDL_API_KEY="your-firebase-api-key"
IOS_BUNDLE_ID="com.yourapp.ios"
ANDROID_PACKAGE="com.yourapp.android"
IOS_APP_STORE_ID="0000000000"

# Firebase Admin SDK
# In production, the server loads /etc/secrets/firebase-adminsdk.json
