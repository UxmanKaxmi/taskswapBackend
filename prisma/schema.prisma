generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id               String           @id @default(uuid())
  text             String
  type             TaskType
  feeling          FeelingTag?
  createdAt        DateTime         @default(now())
  viewCount        Int              @default(0)
  userId           String
  remindAt         DateTime?
  options          String[]         @default([])
  deliverAt        DateTime?
  avatar           String           @default("")
  name             String           @default("")
  pushCount        Int              @default(0)
  latestActivityAt DateTime         @default(now())
  isAlmostThere    Boolean          @default(false)
  completed        Boolean          @default(false)
  completedAt      DateTime?
  isPublic         Boolean          @default(true)
  Comment          Comment[]
  cheers           Cheer[]
  beats            TaskBeat[]
  Push             Push[]
  ReminderNote     ReminderNote[]
  progressUpdates  ProgressUpdate[]
  user             User             @relation(fields: [userId], references: [id])
  Vote             Vote[]
  helpers          User[]           @relation("TaskHelpers")

  @@unique([text, userId])
  @@index([userId, createdAt])
}

model User {
  id                         String           @id @default(cuid())
  email                      String           @unique
  name                       String
  username                   String?          @unique
  photo                      String?
  avatarInitial              String?
  avatarColor                String?
  origin                     String           @default("real")
  createdAt                  DateTime         @default(now())
  lastOpenedAt               DateTime?
  fcmToken                   String?
  provider                   String?
  providerUserId             String?
  appleRefreshToken          String?
  appleRefreshTokenUpdatedAt DateTime?
  Comment                    Comment[]
  cheers                     Cheer[]
  CommentLike                CommentLike[]
  followers                  Follow[]         @relation("FollowedBy")
  following                  Follow[]         @relation("Following")
  sentNotifications          Notification[]   @relation("SenderNotifications")
  notifications              Notification[]   @relation("UserNotifications")
  Push                       Push[]
  referralsRecv              Referral[]       @relation("ReferralsRecv")
  referralsSent              Referral[]       @relation("ReferralsSent")
  referralCode               ReferralCode?
  referralLinks              ReferralLink[]
  featureFlags               FeatureFlags?
  ReminderNote               ReminderNote[]
  progressUpdates            ProgressUpdate[]
  tasks                      Task[]
  Vote                       Vote[]
  helping                    Task[]           @relation("TaskHelpers")
  feedback                   Feedback[]
  authAccounts               AuthAccount[]

  @@unique([provider, providerUserId])
  @@index([origin])
}

model AuthAccount {
  id                         String    @id @default(cuid())
  provider                   String
  providerUserId             String
  userId                     String
  appleRefreshToken          String?
  appleRefreshTokenUpdatedAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model TaskBeat {
  id        String          @id @default(uuid())
  taskId    String
  type      TaskBeatType
  updateId  String?         @unique
  createdAt DateTime        @default(now())
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  update    ProgressUpdate? @relation(fields: [updateId], references: [id], onDelete: Cascade)
  cheers    Cheer[]

  @@index([taskId, createdAt])
  @@index([updateId])
}

model Cheer {
  id                 String   @id @default(uuid())
  taskId             String
  beatId             String
  userId             String
  presetKey          String
  presetTextSnapshot String
  createdAt          DateTime @default(now())
  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  beat               TaskBeat @relation(fields: [beatId], references: [id], onDelete: Cascade)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([beatId, userId])
  @@index([taskId, createdAt])
  @@index([userId, createdAt])
}

model Feedback {
  id            String            @id @default(uuid())
  category      FeedbackCategory?
  message       String
  appVersion    String
  platform      String
  device        String?
  osVersion     String?
  currentScreen String?
  userId        String?
  timeSubmitted DateTime
  createdAt     DateTime          @default(now())
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

enum FeedbackCategory {
  confusing
  bug
  idea
  positive
  other
}

model ReminderNote {
  id        String   @id @default(uuid())
  taskId    String
  senderId  String
  message   String
  createdAt DateTime @default(now())
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([senderId, createdAt])
}

model ProgressUpdate {
  id        String    @id @default(uuid())
  taskId    String
  senderId  String
  text      String
  createdAt DateTime  @default(now())
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  beat      TaskBeat?

  @@index([taskId, createdAt])
  @@index([senderId, createdAt])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("FollowedBy", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  senderId  String?
  type      String
  taskType  String?
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  sender    User?    @relation("SenderNotifications", fields: [senderId], references: [id])
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([senderId, createdAt])
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  option    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([taskId])
}

model Comment {
  id        String        @id @default(uuid())
  text      String
  taskId    String
  userId    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     CommentLike[]

  @@index([taskId, createdAt])
  @@index([userId, createdAt])
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id          String           @id @default(cuid())
  inviterId   String
  inviteeId   String?
  codeUsed    String
  channel     ReferralChannel?
  src         String?
  campaign    String?
  installId   String?
  status      ReferralStatus   @default(PENDING)
  createdAt   DateTime         @default(now())
  qualifiedAt DateTime?
  invitedUser User?            @relation("ReferralsRecv", fields: [inviteeId], references: [id])
  invitedBy   User             @relation("ReferralsSent", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([inviterId, createdAt])
  @@index([installId])
}

model ReferralLink {
  id        String          @id @default(cuid())
  userId    String
  channel   ReferralChannel @default(GENERIC)
  token     String          @unique
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@index([userId, active])
}

model Push {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  source    String   @default("real")
  message   String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@unique([taskId, userId])
  @@index([taskId])
  @@index([source, taskId])
}

enum TaskBeatType {
  post
  update
}

model FeatureFlags {
  id         String   @id @default(cuid())
  userId     String   @unique
  motivation Boolean  @default(true)
  advice     Boolean  @default(true)
  decision   Boolean  @default(true)
  reminder   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
  REJECTED
}

enum ReferralChannel {
  GENERIC
  SMS
  WHATSAPP
  EMAIL
}

enum TaskType {
  reminder
  advice
  decision
  motivation
}

enum FeelingTag {
  stuck
  nervous
  tired
  avoiding_it
  overwhelmed
  almost_there
}
