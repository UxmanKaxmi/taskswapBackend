generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  
  id        String   @id @default(uuid())
  text      String
  type      TaskType
  createdAt DateTime @default(now())
  viewCount     Int      @default(0)
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  remindAt  DateTime? // For reminders
  options   String[]  @default([]) // For decisions (poll options)
  deliverAt DateTime? // For motivation (scheduled delivery)

  avatar      String    @default("")
  name        String    @default("")
  completed   Boolean   @default(false)
  completedAt DateTime? // ✅

  helpers User[] @relation("TaskHelpers")

  ReminderNote ReminderNote[]
  Vote         Vote[]
  Comment      Comment[]
  Push         Push[]


  @@unique([text, userId])
  @@index([userId, createdAt])


  isPublic   Boolean  @default(true)
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
  REJECTED
}

enum ReferralChannel {
  GENERIC
  SMS
  WHATSAPP
  EMAIL
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  photo     String?
  createdAt DateTime @default(now())

  tasks        Task[]
  ReminderNote ReminderNote[]

  followers Follow[] @relation("FollowedBy")
  following Follow[] @relation("Following")

  notifications     Notification[] @relation("UserNotifications")
  sentNotifications Notification[] @relation("SenderNotifications")
  fcmToken          String? // ✅
  helping           Task[]         @relation("TaskHelpers")
  Vote              Vote[]
  Comment           Comment[]
  CommentLike       CommentLike[]

  referralCode  ReferralCode?
  referralsSent Referral[]     @relation("ReferralsSent")
  referralsRecv Referral[]     @relation("ReferralsRecv")
  referralLinks ReferralLink[]

  Push Push[]
}

model ReminderNote {
  id        String   @id @default(uuid())
  taskId    String
  senderId  String
  message   String
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([senderId, createdAt])
}

model Follow {
  id          String   @id @default(uuid())
  follower    User     @relation("FollowedBy", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  senderId String?
  sender   User?   @relation("SenderNotifications", fields: [senderId], references: [id], onDelete: SetNull)

  type      String
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([senderId, createdAt])
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  option    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([taskId])
}

enum TaskType {
  reminder
  advice
  decision
  motivation
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task  Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes CommentLike[]

  @@index([taskId, createdAt])
  @@index([userId, createdAt])
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique // e.g., USMAN123
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id          String           @id @default(cuid())
  inviterId   String
  inviteeId   String?
  codeUsed    String
  channel     ReferralChannel?
  src         String?
  campaign    String?
  installId   String?
  status      ReferralStatus   @default(PENDING)
  createdAt   DateTime         @default(now())
  qualifiedAt DateTime?

  invitedBy   User  @relation("ReferralsSent", fields: [inviterId], references: [id], onDelete: Cascade)
  invitedUser User? @relation("ReferralsRecv", fields: [inviteeId], references: [id], onDelete: SetNull)

  @@index([inviterId, createdAt])
  @@index([installId])
}

model ReferralLink {
  id        String          @id @default(cuid())
  userId    String
  channel   ReferralChannel @default(GENERIC) // ✅ non-null
  token     String          @unique // rotates; appended as ?k=...
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel]) // ✅ now enforced correctly
  @@index([userId, active])
}

model Push {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId]) // one push per user per task
  @@index([taskId])
}