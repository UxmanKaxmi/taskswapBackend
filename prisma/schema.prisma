generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id               String           @id @default(uuid())
  text             String
  type             TaskType
  feeling          FeelingTag?
  createdAt        DateTime         @default(now())
  viewCount        Int              @default(0)
  userId           String
  remindAt         DateTime?
  options          String[]         @default([])
  deliverAt        DateTime?
  avatar           String           @default("")
  name             String           @default("")
  pushCount        Int              @default(0)
  latestActivityAt DateTime         @default(now())
  isAlmostThere    Boolean          @default(false)
  completed        Boolean          @default(false)
  completedAt      DateTime?
  isPublic         Boolean          @default(true)
  isAnonymous      Boolean          @default(false)
  anonAlias        String?
  anonAvatarColor  String?
  circleId         String?
  Comment          Comment[]
  cheers           Cheer[]
  beats            TaskBeat[]
  Push             Push[]
  ReminderNote     ReminderNote[]
  reports          TaskReport[]
  progressUpdates  ProgressUpdate[]
  user             User             @relation(fields: [userId], references: [id])
  circle           Circle?          @relation(fields: [circleId], references: [id], onDelete: SetNull)
  circleMembership CircleMember?
  Vote             Vote[]
  helpers          User[]           @relation("TaskHelpers")

  // text+userId uniqueness is a PARTIAL index (WHERE "circleId" IS NULL) so
  // circle members can carry the shared sentence — raw SQL in the add_circles
  // migration, same technique as one_active_anon_task_per_user.
  @@index([userId, createdAt])
}

model User {
  id                         String           @id @default(cuid())
  email                      String           @unique
  name                       String
  username                   String?          @unique
  photo                      String?
  avatarInitial              String?
  avatarColor                String?
  origin                     String           @default("real")
  createdAt                  DateTime         @default(now())
  lastOpenedAt               DateTime?
  fcmToken                   String?
  provider                   String?
  providerUserId             String?
  appleRefreshToken          String?
  appleRefreshTokenUpdatedAt DateTime?
  firstTimeHints             Json             @default("{}")
  Comment                    Comment[]
  cheers                     Cheer[]
  CommentLike                CommentLike[]
  followers                  Follow[]         @relation("FollowedBy")
  following                  Follow[]         @relation("Following")
  sentNotifications          Notification[]   @relation("SenderNotifications")
  notifications              Notification[]   @relation("UserNotifications")
  Push                       Push[]
  referralsRecv              Referral[]       @relation("ReferralsRecv")
  referralsSent              Referral[]       @relation("ReferralsSent")
  referralCode               ReferralCode?
  referralLinks              ReferralLink[]
  featureFlags               FeatureFlags?
  ReminderNote               ReminderNote[]
  reportsMade                TaskReport[]    @relation("ReporterReports")
  reportsReceived            TaskReport[]    @relation("ReportedUserReports")
  blockedUsers               UserBlock[]      @relation("UserBlocks")
  blockedBy                  UserBlock[]      @relation("UserBlockedBy")
  progressUpdates            ProgressUpdate[]
  tasks                      Task[]
  Vote                       Vote[]
  helping                    Task[]           @relation("TaskHelpers")
  feedback                   Feedback[]
  authAccounts               AuthAccount[]
  scheduledPushes            ScheduledPush[]
  circlesCreated             Circle[]         @relation("CircleCreator")
  circleMemberships          CircleMember[]
  circleInvitesSent          CircleInvite[]   @relation("CircleInviter")

  @@unique([provider, providerUserId])
  @@index([origin])
}

// A circle is a shared frame around individual tasks, never a multi-owner
// task: each member gets their own Task row carrying the shared sentence.
model Circle {
  id          String         @id @default(uuid())
  goalText    String
  status      CircleStatus   @default(active)
  createdById String?
  createdAt   DateTime       @default(now())
  completedAt DateTime?
  dissolvedAt DateTime?
  createdBy   User?          @relation("CircleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members     CircleMember[]
  invites     CircleInvite[]
  tasks       Task[]

  @@index([status, createdAt])
}

// Invite tokens are multi-use until the circle is full (a publicly shared
// link fills the remaining seats); CircleMember.inviteId is the attribution.
model CircleInvite {
  id          String         @id @default(uuid())
  circleId    String
  token       String         @unique
  invitedById String
  createdAt   DateTime       @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  circle      Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  invitedBy   User           @relation("CircleInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  redemptions CircleMember[]

  @@index([circleId, expiresAt])
}

model CircleMember {
  id       String            @id @default(uuid())
  circleId String
  userId   String
  taskId   String?           @unique
  inviteId String?
  state    CircleMemberState @default(active)
  joinedAt DateTime          @default(now())
  leftAt   DateTime?
  doneAt   DateTime?
  circle   Circle            @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  task     Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  invite   CircleInvite?     @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@unique([circleId, userId])
  @@index([userId, state])
}

enum CircleStatus {
  active
  complete
  dissolved
}

enum CircleMemberState {
  active
  left
  done
}

model ScheduledPush {
  id         String    @id @default(uuid())
  userId     String
  taskId     String?
  title      String
  body       String
  data       Json?
  deliverAt  DateTime
  sentAt     DateTime?
  canceledAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deliverAt, sentAt, canceledAt])
  @@index([taskId])
}

model JobLock {
  name     String   @id
  lockedAt DateTime
}

model TaskReport {
  id             String       @id @default(uuid())
  reporterId     String
  taskId         String
  reportedUserId String
  reason         String
  details        String?
  status         ReportStatus @default(pending)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  reviewedAt     DateTime?
  reporter       User         @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  task           Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reportedUser   User         @relation("ReportedUserReports", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@index([taskId, createdAt])
  @@index([reportedUserId, createdAt])
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

enum ReportStatus {
  pending
  reviewed
  dismissed
  action_taken
}

model AuthAccount {
  id                         String    @id @default(cuid())
  provider                   String
  providerUserId             String
  userId                     String
  appleRefreshToken          String?
  appleRefreshTokenUpdatedAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model TaskBeat {
  id        String          @id @default(uuid())
  taskId    String
  type      TaskBeatType
  updateId  String?         @unique
  createdAt DateTime        @default(now())
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  update    ProgressUpdate? @relation(fields: [updateId], references: [id], onDelete: Cascade)
  cheers    Cheer[]

  @@index([taskId, createdAt])
  @@index([updateId])
}

model Cheer {
  id                 String   @id @default(uuid())
  taskId             String
  beatId             String
  userId             String
  presetKey          String
  presetTextSnapshot String
  createdAt          DateTime @default(now())
  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  beat               TaskBeat @relation(fields: [beatId], references: [id], onDelete: Cascade)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([beatId, userId])
  @@index([taskId, createdAt])
  @@index([userId, createdAt])
}

model Feedback {
  id            String            @id @default(uuid())
  category      FeedbackCategory?
  message       String
  appVersion    String
  platform      String
  device        String?
  osVersion     String?
  currentScreen String?
  userId        String?
  timeSubmitted DateTime
  createdAt     DateTime          @default(now())
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

enum FeedbackCategory {
  confusing
  bug
  idea
  positive
  other
}

model ReminderNote {
  id        String   @id @default(uuid())
  taskId    String
  senderId  String
  message   String
  createdAt DateTime @default(now())
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([senderId, createdAt])
}

model ProgressUpdate {
  id        String    @id @default(uuid())
  taskId    String
  senderId  String
  text      String
  createdAt DateTime  @default(now())
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  beat      TaskBeat?

  @@index([taskId, createdAt])
  @@index([senderId, createdAt])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("FollowedBy", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  senderId  String?
  type      String
  taskType  String?
  message   String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  sender    User?    @relation("SenderNotifications", fields: [senderId], references: [id])
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([senderId, createdAt])
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  option    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([taskId])
}

model Comment {
  id        String        @id @default(uuid())
  text      String
  taskId    String
  userId    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     CommentLike[]

  @@index([taskId, createdAt])
  @@index([userId, createdAt])
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id          String           @id @default(cuid())
  inviterId   String
  inviteeId   String?
  codeUsed    String
  channel     ReferralChannel?
  src         String?
  campaign    String?
  installId   String?
  status      ReferralStatus   @default(PENDING)
  createdAt   DateTime         @default(now())
  qualifiedAt DateTime?
  invitedUser User?            @relation("ReferralsRecv", fields: [inviteeId], references: [id])
  invitedBy   User             @relation("ReferralsSent", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([inviterId, createdAt])
  @@index([installId])
}

model ReferralLink {
  id        String          @id @default(cuid())
  userId    String
  channel   ReferralChannel @default(GENERIC)
  token     String          @unique
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@index([userId, active])
}

model Push {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  source    String   @default("real")
  message   String?
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@unique([taskId, userId])
  @@index([taskId])
  @@index([source, taskId])
}

enum TaskBeatType {
  post
  update
}

model FeatureFlags {
  id         String   @id @default(cuid())
  userId     String   @unique
  motivation Boolean  @default(true)
  advice     Boolean  @default(true)
  decision   Boolean  @default(true)
  reminder   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
  REJECTED
}

enum ReferralChannel {
  GENERIC
  SMS
  WHATSAPP
  EMAIL
}

enum TaskType {
  reminder
  advice
  decision
  motivation
}

enum FeelingTag {
  stuck
  nervous
  tired
  avoiding_it
  overwhelmed
  almost_there
}
