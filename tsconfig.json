{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "baseUrl": "./src",
    "paths": {
      "@app/*": ["app/*"],
      "@features/*": ["features/*"],
      "@shared/*": ["shared/*"],
      "@assets/*": ["assets/*"],
      "@lib/*": ["lib/*"],
      "@navigation/*": ["navigation/*"],
      "@db/*": ["db/*"],
      "@middleware/*": ["middleware/*"],
      "@types/*": ["types/*"],
      "@utils/*": ["utils/*"],
      "@errors/*": ["errors/*"],
      "@models/*": ["models/*"],
      "@config/*": ["config/*"]
    }
  },
  "include": ["src/**/*", "scripts/testNotificationInApp.ts"]
}
